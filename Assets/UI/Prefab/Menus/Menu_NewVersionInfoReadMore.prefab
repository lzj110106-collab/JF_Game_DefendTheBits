    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 1
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1.4
  m_Text: 'New changes in "Defend the Bits" V1.1 Includes some major changes to the
    value of currency.

    - Gems are now Keys

    - Keys will randomly drop when defeating Bad-Bits

    - Keys are now rewarded when you earn 1 - 3 stars

    - Characters are now easier to unlock with reduced costs


    Other changes include


    - Balancing to levels, reduction of the amount of Bad-Bits which now speeds up
    level completion

    - Abilitys have been replaced

    - Easier Quests

    - Minor Bug fixes

'
