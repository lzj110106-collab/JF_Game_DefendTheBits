--- !u!114 &114000010194077120
MonoBehaviour:
  m_ObjectHideFlags: 1
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 100100000}
  m_GameObject: {fileID: 1000013637776168}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 708705254, guid: f5f67c52d1564df4a8936ccd202a3bd8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
    m_TypeName: UnityEngine.UI.MaskableGraphic+CullStateChangedEvent, UnityEngine.UI,
      Version=1.0.0.0, Culture=neutral, PublicKeyToken=null
  m_FontData:
    m_Font: {fileID: 12800000, guid: f8b361ad8e8f7e147bdac9ebcb8a6c18, type: 3}
    m_FontSize: 34
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 1
    m_MaxSize: 200
    m_Alignment: 1
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 0.67
  m_Text: "\u53D1\u884C\u5546\n\n<Color=\"#BFD8F6\">\r\u4E1C\u54C1\u6E38\u620F</Color>\r\n\r\n\n\u5236\u4F5C\u4EBA\r\n\r\n<Color=\"#BFD8F6FF\">\u5F3A\u5F3A</color>\r\n\r\n\n\u9879\u76EE\u7ECF\u7406\n\n<Color=\"#BFD8F6FF\">\u82CF\u535A</color>\r\n\n\n\u6280\u672F\r\n\r\n<Color=\"#BFD8F6FF\">\u5E84\u535A\u58EB</Color>\r\n\r\n\n\u7F8E\u672F\r\n\r\n<Color=\"#BFD8F6FF\">\u8D75\u5C11\u4E1C</Color>\r\n\r\n\n\r\u6D4B\u8BD5\n\r\n<Color=\"#BFD8F6FF\">\u767D\u8018\u8D6B\n\n\u90B9\u4E1C\u7B11</Color>\r\n\n\n\u8054\u7CFB\u5BA2\u670D\n\r\n<Color=\"#BFD8F6FF\">\u5FAE\u4FE1\uFF1Aeast2westapp</Color>\r\n\n<Color=\"#BFD8F6FF\">QQ\uFF1A2896875104</Color>\r\n\n<Color=\"#BFD8F6FF\">\u7535\u8BDD\uFF1A4009001565</Color>\r\n\n<Color=\"#BFD8F6FF\">\r\u90AE\u7BB1\uFF1Akf@east2west.cn</Color>\r\n\n\n\nPLAYSIDE
    STUDIOS\r\n\r\nCEO/Creative Director\r\n\r\n<Color=\"#BFD8F6\">Gerry Sakkas</Color>\r\n\r\nCOO\r\n\r\n<Color=\"#BFD8F6FF\">Tejesh
    Munusamy</color>\r\n\r\nDirectors\r\n\r\n<Color=\"#BFD8F6FF\">Mark Goulopoulos</Color>\r\n\n<Color=\"#BFD8F6FF\">Aaron
    Pasias</Color>\r\n\r\nProducers\r\n\r\n<Color=\"#BFD8F6FF\">Danny Armstrong</Color>\r\n\n<Color=\"#BFD8F6FF\">Erin
    Halpenny</Color>\r\n\r\nLead Artist\r\n\r\n<Color=\"#BFD8F6FF\">Adam Bax</Color>\r\n\r\nLead
    Game Designer\r\n\r\n<Color=\"#BFD8F6FF\">Kristel Villegas</Color>\r\n\r\nLead
    Engineer\r\n\r\n<Color=\"#BFD8F6FF\">Scott Wickens</Color>\r\n\r\nUI / Concept
    Artist\r\n\r\n<Color=\"#BFD8F6FF\">Nick Merrett</Color>\r\n\r\nTechnical Animator\r\n\r\n<Color=\"#BFD8F6FF\">Alastair
    Richardson</Color>\r\n\r\nAnimators\r\n\r\n<Color=\"#BFD8F6FF\">Jake Loverso</Color>\r\n\n<Color=\"#BFD8F6FF\">Benjamin
    Swallow</Color>\r\n\r\nArtists\r\n\r\n<Color=\"#BFD8F6FF\">Rhyl Mayes</Color>\r\n\n<Color=\"#BFD8F6FF\">Ryan
    McMahon</Color>\r\n\n<Color=\"#BFD8F6FF\">Kelsey Wallis</Color>\r\n\n<Color=\"#BFD8F6FF\">Ello
    Wihongi</Color>\r\n\n<Color=\"#BFD8F6FF\">Harry Stringer</Color>\r\n\n<Color=\"#BFD8F6FF\">Perry
    Zielonka</Color>\r\n\n<Color=\"#BFD8F6FF\">Jesse Barratt</Color>\r\n\n<Color=\"#BFD8F6FF\">Arky
    Fitzwater</Color>\r\n\n<Color=\"#BFD8F6FF\">Aaron Martin</Color>\r\n\n<Color=\"#BFD8F6FF\">Jordan
    Pascal</Color>\r\n\n<Color=\"#BFD8F6FF\">Grigor Pedrioli</Color>\r\n\n<Color=\"#BFD8F6FF\">Stephen
    Schulze</Color>\r\n\n<Color=\"#BFD8F6FF\">Ben Swallow</Color>\r\n\n<Color=\"#BFD8F6FF\">Taylah
    Walker</Color>\r\n\r\nDesigners\r\n\r\n<Color=\"#BFD8F6FF\">Matthew Flach</Color>\r\n\n<Color=\"#BFD8F6FF\">Huy
    Hoang Tran</Color>\r\n\r\nEngineers\r\n\r\n<Color=\"#BFD8F6FF\">Darcy Abell</Color>\r\n\n<Color=\"#BFD8F6FF\">Jamie
    T. Bentley</Color>\r\n\n<Color=\"#BFD8F6FF\">Ed Booth</Color>\r\n\n<Color=\"#BFD8F6FF\">Shane
    Coates</Color>\r\n\n<Color=\"#BFD8F6FF\">Samuel Cole</Color>\r\n\n<Color=\"#BFD8F6FF\">Jarrod
    Dowsey</Color>\r\n\n<Color=\"#BFD8F6FF\">Stefan Giapantzakis</Color>\r\n\n<Color=\"#BFD8F6FF\">Justin
    Kiesskalt</Color>\r\n\n<Color=\"#BFD8F6FF\">Paul Rahme</Color>\r\n\r\nQA\r\n\r\n<Color=\"#BFD8F6FF\">Hugh
    Trieu</Color>\r\n\r\nStudio Manager\r\n\r\n<Color=\"#BFD8F6FF\">Nikki Bombak</Color>\n\n\n\n\n\n\n\n\n\n"
